# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=attachments

# Direct Postgres connection string from Supabase (Session Mode port 5432)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Optional override: true/require/false (auto-detected if omitted)
DATABASE_SSL=require

# Optional: set true to print every SQL query (slower when enabled)
DB_LOG_QUERIES=false

# JWT secret (generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Optional: bcrypt cost factor (default: 12 in production, 8 in development)
BCRYPT_ROUNDS=8

# Server
PORT=3000
NODE_ENV=development
